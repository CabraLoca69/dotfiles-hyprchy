#!/usr/bin/env bash

set -e

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colores
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${GREEN}[+]${NC} $1"; }
warning() { echo -e "${YELLOW}[!]${NC} $1"; }
error()   { echo -e "${RED}[x]${NC} $1"; }
section() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}"; }

# ──────────────────────────────────────────────
# Dependencias
# ──────────────────────────────────────────────

PACMAN_DEPS=(
    # Hyprland y compositor
    hyprland
    hyprlock
    hypridle
    hyprsunset
    hyprpicker
    xdg-desktop-portal-hyprland
    xdg-desktop-portal-gtk
    uwsm

    # Waybar y notificaciones
    waybar
    mako
    playerctl
    pamixer
    wireplumber
    wl-clipboard
    calcurse

    # Terminal y shell
    alacritty
    fzf
    jq
    bat
    eza
    starship
    zoxide

    # Archivos y sistema
    nautilus
    gvfs-mtp
    grim
    slurp
    swaybg
    polkit-gnome
    gnome-keyring
    gnome-keyring
    libsecret

    # Fuentes
    noto-fonts
    noto-fonts-emoji
    ttf-jetbrains-mono-nerd
)

AUR_DEPS=(
    elephant
    elephant-bluetooth
    elephant-calc
    elephant-clipboard
    elephant-desktopapplications
    elephant-files
    elephant-menus
    elephant-providerlist
    elephant-runner
    elephant-symbols
    elephant-todo
    elephant-unicode
    elephant-websearch
    xdg-terminal-exec
    yaru-icon-theme
    linux-wallpaperengine-git
    sunwait
    hyprland-preview-share-picker-git
)

CACHYOS_DEPS=(
    walker
)

install_pacman_deps() {
    section "Instalando dependencias (pacman)"

    local missing=()
    for pkg in "${PACMAN_DEPS[@]}"; do
        if ! pacman -Qi "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        info "Todas las dependencias pacman ya están instaladas."
    else
        info "Paquetes a instalar: ${missing[*]}"
        sudo pacman -S --needed "${missing[@]}"
    fi
}

install_aur_deps() {
    section "Instalando dependencias (AUR)"

    if ! command -v paru &>/dev/null; then
        error "paru no encontrado. Instalalo primero: https://github.com/Morganamilo/paru"
        exit 1
    fi

    local missing=()
    for pkg in "${AUR_DEPS[@]}"; do
        if ! pacman -Qi "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        info "Todas las dependencias AUR ya están instaladas."
    else
        info "Paquetes AUR a instalar: ${missing[*]}"
        paru -S --needed "${missing[@]}"
    fi
}

install_cachyos_deps() {
    section "Instalando dependencias (CachyOS)"

    if ! grep -q "^\[cachyos\]" /etc/pacman.conf 2>/dev/null; then
        warning "Repo de CachyOS no encontrado en pacman.conf."
        warning "Estos paquetes no se van a instalar: ${CACHYOS_DEPS[*]}"
        warning "Sin walker el launcher no va a funcionar."
        warning "Seguí la guía en https://wiki.cachyos.net/installation/repos/ para agregarlo,"
        warning "o instalá walker desde AUR: paru -S walker-bin"
        return
    fi

    local missing=()
    for pkg in "${CACHYOS_DEPS[@]}"; do
        if ! pacman -Qi "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        info "Todas las dependencias CachyOS ya están instaladas."
    else
        info "Paquetes CachyOS a instalar: ${missing[*]}"
        sudo pacman -S --needed "${missing[@]}"
    fi
}

# ──────────────────────────────────────────────
# PATH
# ──────────────────────────────────────────────

setup_path() {
    section "Configurando PATH"

    local shell_rc=""
    if [[ "$SHELL" == *"fish"* ]]; then
        shell_rc="$HOME/.config/fish/config.fish"
        local path_line="fish_add_path \$HOME/.local/bin"
    elif [[ "$SHELL" == *"zsh"* ]]; then
        shell_rc="$HOME/.zshrc"
        local path_line='export PATH="$HOME/.local/bin:$PATH"'
    else
        shell_rc="$HOME/.bashrc"
        local path_line='export PATH="$HOME/.local/bin:$PATH"'
    fi

    if grep -q "\.local/bin" "$shell_rc" 2>/dev/null; then
        info "PATH ya configurado en $shell_rc"
    else
        echo "$path_line" >> "$shell_rc"
        info "PATH agregado a $shell_rc"
        warning "Reiniciá la shell o ejecutá: source $shell_rc"
    fi
}

# ──────────────────────────────────────────────
# Symlinks
# ──────────────────────────────────────────────

symlink() {
    local src="$1"
    local dst="$2"

    if [ -L "$dst" ]; then
        warning "Ya existe symlink: $dst → reemplazando"
        rm "$dst"
    elif [ -e "$dst" ]; then
        warning "Ya existe (no es symlink): $dst → haciendo backup en ${dst}.bak"
        mv "$dst" "${dst}.bak"
    fi

    mkdir -p "$(dirname "$dst")"
    ln -s "$src" "$dst"
    info "$dst → $src"
}

create_symlinks() {
    section "Creando symlinks"

    for dir in "$DOTFILES_DIR"/.config/*/; do
        name="$(basename "$dir")"
        symlink "$dir" "$HOME/.config/$name"
    done

    for dir in "$DOTFILES_DIR"/.local/share/*/; do
        name="$(basename "$dir")"
        symlink "$dir" "$HOME/.local/share/$name"
    done

    mkdir -p "$HOME/.local/bin"
    for file in "$DOTFILES_DIR"/.local/bin/*; do
        name="$(basename "$file")"
        symlink "$file" "$HOME/.local/bin/$name"
    done
}

# ──────────────────────────────────────────────
# Avisos post-instalación
# ──────────────────────────────────────────────

post_install_notes() {
    section "Notas post-instalación"

    echo -e "${YELLOW}Atención — configuración manual requerida:${NC}"
    echo ""
    echo "  1. waybar-cpu-watts usa paths de hwmon hardcodeados."
    echo "     Verificá que sean correctos en tu hardware:"
    echo "       /sys/class/hwmon/hwmon3/energy9_input  (energía CPU)"
    echo "       /sys/class/hwmon/hwmon4/temp1_input    (temperatura CPU)"
    echo "     Usá 'ls /sys/class/hwmon/' y 'cat /sys/class/hwmon/hwmon*/name'"
    echo "     para identificar los correctos."
    echo ""
    echo "  2. waybar-gpu usa ROCm (AMD)."
    echo "     Si el hardware es distinto ajustá el script manualmente."
    echo ""
    echo "  3. linux-wallpaperengine requiere Wallpaper Engine instalado en Steam."
    echo "     Sin eso el script no funciona, pero no rompe nada al iniciar."
    echo "     Puedes descomentar la 6ta linea del autostart para que se lanze swaybg"
    echo "     Deberias instalar Swaybg si no lo tienes"
    echo "     Aun asi de estas dotfiles se elimino el handler de fondos, buena suerte"
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
    echo -e "${CYAN}"
    echo "  ┌─────────────────────────────┐"
    echo "  │     dotfiles installer      │"
    echo "  └─────────────────────────────┘"
    echo -e "${NC}"

    install_pacman_deps
    install_aur_deps
    install_cachyos_deps
    setup_path
    create_symlinks
    post_install_notes

    echo ""
    info "Instalación completa."
}

main "$@"