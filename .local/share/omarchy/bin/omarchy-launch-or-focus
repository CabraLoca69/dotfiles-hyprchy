#!/bin/bash
# omarchy:summary=Launch an app or focus an existing window matching a pattern
# omarchy:args=[-f|--floating] [-d|--decorated] [-t|--title <title>] <window-pattern> [launch-command]

floating="false"
decorated=""
title=""

while [[ "$1" == -* ]]; do
    case "$1" in
        -f|--floating)
            floating=true
            shift
            ;;
        -d|--decorated)
            decorated=true
            shift
            ;;
        -t|--title)
            title="$2"
            shift 2
            ;;
        -t=*|--title=*)
            title="${1#*=}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [[ -z "$1" ]]; then
    echo "Usage: omarchy-launch-or-focus [-f] [-d] [-t title] <window-pattern> [launch-command]"
    exit 1
fi

WINDOW_PATTERN="$1"
USER_COMMAND="${2:-$WINDOW_PATTERN}"

if $floating; then
    LAUNCH_COMMAND="omarchy-launch-floating-terminal ${decorated:+-d} ${title:+-t \"$title\"} $USER_COMMAND"
else
    LAUNCH_COMMAND="xdg-terminal-exec --app-id=$title $USER_COMMAND"
fi

WINDOW_ADDRESS=$(hyprctl clients -j | jq -r --arg p "$WINDOW_PATTERN" '.[]|select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i")))|.address' | head -n1)

if [[ -n $WINDOW_ADDRESS ]]; then
    hyprctl dispatch "hl.dsp.focus({ window = \"address:$WINDOW_ADDRESS\" })" >/dev/null 2>&1 || hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS"
else
    eval exec setsid $LAUNCH_COMMAND
fi