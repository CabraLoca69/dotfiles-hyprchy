#!/bin/bash
# omarchy:summary=Launch a floating terminal (optionally decorated)
# omarchy:args=[-d|--decorated] [-t|--title <title>] [command]

decorated=false
title="Terminal"

while [[ "$1" == -* ]]; do
    case "$1" in
        -d|--decorated)
            decorated=true
            shift
            ;;
        -t|--title)
            title="$2"
            shift 2
            ;;
        -t=*|--title=*)
            title="${1#*=}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

cmd="$*"

if $decorated; then
    if [[ -z "$cmd" ]]; then
        exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.floating.terminal --title="$title" -e bash -c "omarchy-show-logo; exec bash"
    else
        exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.floating.terminal --title="$title" -e bash -c "omarchy-show-logo; $cmd; if (( \$? != 130 )); then omarchy-show-done; fi"
    fi
else
    if [[ -z "$cmd" ]]; then
        exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.floating.terminal --title="$title" -e bash
    else
        exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.floating.terminal --title="$title" -e bash -c "$cmd"
    fi
fi