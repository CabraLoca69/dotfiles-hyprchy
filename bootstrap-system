#!/usr/bin/env bash

set -e

# Colores
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${GREEN}[+]${NC} $1"; }
warning() { echo -e "${YELLOW}[!]${NC} $1"; }
error()   { echo -e "${RED}[x]${NC} $1"; }
section() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}"; }

MANUAL_NOTES=()

ask_yes_no() {
    local answer
    read -rp "$(echo -e "${YELLOW}?${NC} $1 [s/N]: ")" answer
    [[ "$answer" =~ ^[sSyY]$ ]]
}

install_pkgs() {
    # $1 = "pacman" o "aur", resto = paquetes
    local mgr="$1"; shift
    local pkgs=("$@")
    local missing=()

    for pkg in "${pkgs[@]}"; do
        if ! pacman -Qi "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        info "Ya instalados: ${pkgs[*]}"
        return
    fi

    info "Instalando: ${missing[*]}"
    if [ "$mgr" = "pacman" ]; then
        sudo pacman -S --needed "${missing[@]}"
    else
        if ! command -v paru &>/dev/null; then
            error "paru no encontrado, no puedo instalar paquetes AUR: ${missing[*]}"
            return
        fi
        paru -S --needed "${missing[@]}"
    fi
}

# ──────────────────────────────────────────────
# Display Manager
# ──────────────────────────────────────────────

setup_display_manager() {
    section "Display Manager"

    # ¿Ya hay uno instalado y habilitado?
    if systemctl is-enabled sddm.service &>/dev/null \
        || systemctl is-enabled gdm.service &>/dev/null \
        || systemctl is-enabled lightdm.service &>/dev/null \
        || systemctl is-enabled greetd.service &>/dev/null; then
        info "Ya hay un display manager habilitado ($(systemctl list-unit-files --state=enabled | grep -Eo 'sddm|gdm|lightdm|greetd' | head -1).service)."
        return
    fi

    warning "No se detectó ningún display manager habilitado."
    warning "Sin esto, al bootear vas a caer en el TTY y hay que lanzar Hyprland a mano."

    if ! pacman -Qi sddm &>/dev/null; then
        install_pkgs pacman sddm
    else
        info "sddm ya está instalado, falta habilitarlo."
    fi

    sudo systemctl enable sddm.service
    info "sddm habilitado. Con el próximo reinicio deberías ver la pantalla de login."

    # Verificamos que exista al menos una sesión Wayland para que sddm tenga qué mostrar
    if ! ls /usr/share/wayland-sessions/*.desktop &>/dev/null \
        && ! ls /usr/local/share/wayland-sessions/*.desktop &>/dev/null; then
        warning "No encontré ningún .desktop en wayland-sessions."
        MANUAL_NOTES+=("SDDM no encontró sesiones Wayland (/usr/share/wayland-sessions/). Verificá que uwsm/hyprland hayan generado un archivo .desktop de sesión, o creá uno manualmente.")
    fi
}

# ──────────────────────────────────────────────
# multilib
# ──────────────────────────────────────────────

enable_multilib() {
    section "Repositorio [multilib]"

    if grep -q "^\[multilib\]" /etc/pacman.conf; then
        info "[multilib] ya está habilitado."
        return
    fi

    warning "[multilib] está deshabilitado (necesario para Steam/Wine/lib32-*)."
    if ask_yes_no "¿Habilitarlo ahora?"; then
        sudo cp /etc/pacman.conf /etc/pacman.conf.bak
        info "Backup guardado en /etc/pacman.conf.bak"

        # Descomenta el bloque [multilib] y su Include de abajo
        sudo sed -i '/^#\[multilib\]/,/^#Include/s/^#//' /etc/pacman.conf

        if grep -q "^\[multilib\]" /etc/pacman.conf; then
            info "[multilib] habilitado."
            sudo pacman -Sy
        else
            error "No pude habilitarlo automáticamente. Editá /etc/pacman.conf a mano."
            MANUAL_NOTES+=("Habilitar [multilib] a mano en /etc/pacman.conf (descomentar el bloque) y correr 'sudo pacman -Sy'.")
        fi
    else
        MANUAL_NOTES+=("[multilib] sigue deshabilitado. Paquetes lib32-* no se van a poder instalar hasta que lo habilites.")
    fi
}

# ──────────────────────────────────────────────
# Servicios systemd
# ──────────────────────────────────────────────

enable_service() {
    local svc="$1"
    local scope="${2:-system}"  # system | user

    if [ "$scope" = "user" ]; then
        if systemctl --user is-enabled "$svc" &>/dev/null; then
            info "$svc (user) ya está habilitado."
        else
            if systemctl --user list-unit-files "$svc" &>/dev/null; then
                systemctl --user enable --now "$svc"
                info "$svc (user) habilitado y arrancado."
            else
                warning "$svc (user) no está instalado, salteando."
            fi
        fi
    else
        if systemctl is-enabled "$svc" &>/dev/null; then
            info "$svc ya está habilitado."
        else
            if systemctl list-unit-files "$svc" &>/dev/null; then
                sudo systemctl enable --now "$svc"
                info "$svc habilitado y arrancado."
            else
                warning "$svc no está instalado, salteando."
            fi
        fi
    fi
}

enable_core_services() {
    section "Servicios de sistema"

    enable_service NetworkManager.service
    enable_service bluetooth.service

    # seatd solo hace falta si no estás manejando la sesión con logind (uwsm/sddm ya lo cubren normalmente)
    if pacman -Qi seatd &>/dev/null; then
        enable_service seatd.service
    fi
}

# ──────────────────────────────────────────────
# Grupos de usuario
# ──────────────────────────────────────────────

add_user_groups() {
    section "Grupos de usuario"

    local groups=(video input)
    # 'seat' solo existe si seatd está instalado
    if getent group seat &>/dev/null; then
        groups+=(seat)
    fi

    local user="${SUDO_USER:-$USER}"
    local changed=false

    for grp in "${groups[@]}"; do
        if id -nG "$user" | grep -qw "$grp"; then
            info "$user ya está en el grupo $grp."
        else
            sudo usermod -aG "$grp" "$user"
            info "$user agregado al grupo $grp."
            changed=true
        fi
    done

    if [ "$changed" = true ]; then
        MANUAL_NOTES+=("Se te agregaron grupos nuevos. Cerrá sesión y volvé a entrar (o reiniciá) para que tomen efecto.")
    fi
}

# ──────────────────────────────────────────────
# gnome-keyring vía PAM
# ──────────────────────────────────────────────

fix_keyring_pam() {
    section "Integración de gnome-keyring con PAM"

    if ! pacman -Qi gnome-keyring &>/dev/null; then
        warning "gnome-keyring no está instalado, salteando."
        return
    fi

    # Detecta qué servicio PAM usa tu login manager (sddm, sddm-autologin, gdm, etc.)
    local pam_files=()
    for f in /etc/pam.d/sddm /etc/pam.d/sddm-autologin /etc/pam.d/gdm-password /etc/pam.d/login; do
        [ -f "$f" ] && pam_files+=("$f")
    done

    if [ ${#pam_files[@]} -eq 0 ]; then
        warning "No encontré archivos PAM conocidos (sddm/gdm/login). Configurá el keyring manualmente."
        return
    fi

    for f in "${pam_files[@]}"; do
        if grep -q "pam_gnome_keyring.so" "$f"; then
            info "$f ya tiene pam_gnome_keyring configurado."
            continue
        fi

        if ask_yes_no "¿Agregar pam_gnome_keyring a $f para que el keyring se desbloquee solo al loguear?"; then
            sudo cp "$f" "${f}.bak"
            # auth: después de la línea que dice "auth include system-login" o similar
            sudo sed -i '/^auth.*include.*system-/a auth       optional     pam_gnome_keyring.so' "$f"
            sudo sed -i '/^session.*include.*system-/a session    optional     pam_gnome_keyring.so' "$f"
            info "$f actualizado (backup en ${f}.bak)."
        fi
    done
}

# ──────────────────────────────────────────────
# Notas finales
# ──────────────────────────────────────────────

print_manual_notes() {
    if [ ${#MANUAL_NOTES[@]} -eq 0 ]; then
        return
    fi
    section "Pasos manuales pendientes"
    local i=1
    for note in "${MANUAL_NOTES[@]}"; do
        echo -e "${YELLOW}$i.${NC} $note"
        echo ""
        i=$((i+1))
    done
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

main() {
    echo -e "${CYAN}"
    echo "  ┌─────────────────────────────┐"
    echo "  │   system bootstrap          │"
    echo "  └─────────────────────────────┘"
    echo -e "${NC}"

    setup_display_manager
    enable_multilib
    enable_core_services
    add_user_groups
    fix_keyring_pam

    print_manual_notes

    echo ""
    info "Bootstrap completo."
}

main "$@"